# Postgres — app role with INSERT/UPDATE on mlm.* and SELECT on auth.*
# Production: connect through PgBouncer on the DB host (port 6432).
DATABASE_URL=postgres://app_write:CHANGEME@db.internal:6432/vicionpower

# Better Auth
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=https://app.vicionpower.com
BETTER_AUTH_TRUSTED_ORIGINS=https://app.vicionpower.com

# Redis — sessions cache + rate limit + BullMQ
REDIS_URL=redis://redis.internal:6379

# Email (transactional, for verification + password reset)
RESEND_API_KEY=re_change_me

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption key for mlm.person.ssn_encrypted (pgcrypto)
PII_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

NODE_ENV=production
PORT=3000
