# vp-payments — entorno de PRUEBA (modo test de Stripe). Copia a un archivo
# (p.ej. backend/vp-payments.test.env) y córrelo con:
#   PAYMENTS_ENV_FILE=backend/vp-payments.test.env /opt/vicion/bin/vp-payments
# (o:  cd backend/vp-engine && PAYMENTS_ENV_FILE=../vp-payments.test.env go run ./cmd/vp-payments)

ENV=development
LOG_LEVEL=debug
PAYMENTS_HTTP_ADDR=0.0.0.0:9095

# --- Stripe TEST ---  (NO uses sk_live aquí)
# Saca sk_test_ de: Stripe → Developers → API keys → "Test mode".
STRIPE_SECRET_KEY=sk_test_xxx
# El webhook secret para LOCAL lo imprime `stripe listen` (NO el del dashboard):
#   stripe listen --forward-to localhost:9095/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxx_de_stripe_listen
PAYMENTS_STRIPE_PRODUCT_ID=prod_Uh7XFJyzQusjkl
PAYMENTS_METHODS=card

# --- DB ---  ⚠️ usa una DB de STAGING con el schema + los 9 packs.
# Si apuntas a RDS productiva, los pagos test crean afiliados REALES en el árbol.
DATABASE_URL=postgres://vp_engine:***@<staging-host>:5432/vicion?sslmode=require

# --- Token compartido con el BFF Next (mismo valor en frontend/.env.local) ---
PAYMENTS_SERVICE_TOKEN=__openssl_rand_-hex_32__

PAYMENTS_SUCCESS_URL=http://localhost:3000/dashboard/packages?paid=1&session_id={CHECKOUT_SESSION_ID}
PAYMENTS_CANCEL_URL=http://localhost:3000/dashboard/packages?canceled=1
