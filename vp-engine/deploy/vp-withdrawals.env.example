# vp-withdrawals — API de retiros (solicitud del miembro + cola admin + pago).
#
# DESPLIEGUE: Docker Compose (deploy/compose/server1.yml, network_mode: host),
# en la EC2 APP (i-060e76a6c26bded35), junto a vp-engine y vp-payments.
# NO es un servicio systemd.
#
# Este archivo es una PLANTILLA de referencia. En producción el env-file real
# (/run/vicionpower/vp-withdrawals.env, chmod 600) lo GENERA el deploy en el
# host — ver _meta/devops/scripts/remote-deploy.sh — a partir de:
#
#   1. SSM Parameter Store:  /vicionpower/prod/vp-withdrawals/<VARIABLE>
#   2. AWS Secrets Manager:  vicionpower/prod/vp-withdrawals  (JSON k/v)
#
# Secrets Manager se mezcla DESPUÉS de SSM, así que gana sobre cualquier copia
# stale. Los valores sensibles de aquí abajo (DATABASE_URL, SERVICE_TOKEN,
# BMP_CLIENT_SECRET) van en Secrets Manager; el resto en SSM.
#
# NUNCA commitear el archivo real: contiene el Client-Secret de BMP.
# Sólo esta plantilla (*.env.example) pertenece al repo.

# ==========================================================================
# ORDEN DE DESPLIEGUE — OBLIGATORIO
# ==========================================================================
# Aplicar a RDS las migraciones ANTES de arrancar el binario:
#
#   _meta/migration/49_withdrawal_bmp_and_fee.sql
#   _meta/migration/50_bmp_account_link.sql
#
# Al revés (binario primero) los INSERT fallan por columnas y tablas
# inexistentes: la 49 agrega las columnas de fee/BMP a la fila de retiro y la
# 50 crea la tabla del vínculo de email BMP alterno. El servicio arranca igual
# —la config no toca la base— y recién revienta al primer retiro solicitado.
# ==========================================================================

ENV=production
LOG_LEVEL=info

# --- Base de datos ---
# EL MISMO RDS QUE vp-payments, con el mismo rol de escritura. No es opcional:
# el débito contable del ledger y el cambio de estado del retiro ocurren en UNA
# sola transacción de Postgres. Apuntar este servicio a otra base (o a la
# réplica de lectura) rompe esa atomicidad y puede pagar sin debitar.
# Requerido — sin él LoadConfig falla al arranque.
DATABASE_URL=postgres://vp_engine:CHANGE_ME@<rds-host>:5432/vicion?sslmode=require

# --- Servicio / red ---
# Bind 0.0.0.0 (lección del bug de vp-payments: loopback en contenedor lo deja
# inalcanzable). El acceso externo lo controla el SG + Caddy, no el bind.
# Default del código: 0.0.0.0:9097.
WITHDRAWALS_HTTP_ADDR=0.0.0.0:9097

# Shared secret con el BFF Next (header X-VP-Service-Token).
# MISMO VALOR que usa vp-payments — pero OJO: en el env de payments la variable
# se llama PAYMENTS_SERVICE_TOKEN y aquí se llama SERVICE_TOKEN (sin prefijo).
# Requerido — sin él LoadConfig falla al arranque.
SERVICE_TOKEN=CHANGE_ME

# ==========================================================================
# ADMINS — CUIDADO: los nombres NO llevan prefijo
# ==========================================================================
# vp-withdrawals lee ADMIN_EMAILS / SUPER_ADMIN_EMAILS.
# vp-payments   lee PAYMENTS_ADMIN_EMAILS / PAYMENTS_SUPER_ADMIN_EMAILS.
#
# Copiar el env de payments tal cual deja ADMIN_EMAILS VACÍO aquí: los admins
# normales pierden la cola de retiros y sólo entra el super-admin (que tiene
# default en el código). El síntoma es silencioso — no hay error de arranque,
# simplemente la cola responde 403 a todo el equipo de operaciones.
# ==========================================================================
# Lista separada por comas. Alternativa sin redeploy: marcar
# mlm.person.is_admin = true (el servicio también consulta la base).
ADMIN_EMAILS=devfidubit@gmail.com,gabgarluc@msn.com
# Rol super_admin (acceso total). Son admins aunque NO estén en ADMIN_EMAILS ni
# en mlm.person.is_admin. Default del código: devfidubit@gmail.com.
SUPER_ADMIN_EMAILS=devfidubit@gmail.com

# --- Verificación H-2 del id token Cognito que reenvía el BFF ---
# Mismos valores que vp-payments / vp-support. Si faltan, el servicio arranca
# con un Warn y CONFÍA en el email declarado por el llamador (no fail-closed):
# cualquiera con el SERVICE_TOKEN podría hacerse pasar por admin.
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_CHANGE_ME
COGNITO_CLIENT_ID=CHANGE_ME

# --- BMP (verificación del afiliado en Be MindPower) ---
# Headers reales del contrato: x-client-id / x-client-secret.
# Ruta: /api/v1/mindpower/user-verification
#
# BMP_BASE_URL es OBLIGATORIO con ENV=production: el default del código apunta
# al backend de DEV de BMP, que no conoce afiliados reales y responde
# exists:false para todos. Sin la variable, LoadConfig falla a propósito en vez
# de decidir pagos en silencio contra dev.
#
# OJO: es solo el HOST. La ruta la agrega el código. Si copias una URL completa
# (p. ej. la variable ENDPOINT_BMP de .env.local, que trae host+ruta), el
# cliente pedirá .../user-verification/api/v1/mindpower/user-verification y BMP
# responderá 404 en todas las verificaciones.
#
# Producción: https://apis.be-mindpower.net
# Dev:        https://dev-backend.be-mindpower.net
BMP_BASE_URL=https://apis.be-mindpower.net
BMP_CLIENT_ID=CHANGE_ME
# SENSIBLE — va en Secrets Manager, nunca en el repo ni en un SSM sin cifrar.
BMP_CLIENT_SECRET=CHANGE_ME

# ==========================================================================
# WITHDRAWALS_REQUIRE_BMP — candado BMP al pagar. DEFAULT: true
# ==========================================================================
# true  (default): no se puede pagar un retiro sin verificación BMP válida y
#                  fresca. Es el modo correcto en producción.
#
# false: el resultado de la verificación NO impide pagar.
#        Es el modo para desplegar ANTES de tener credenciales productivas de
#        BMP — con el candado puesto y sin credenciales, todos los pagos
#        quedarían congelados. Mientras esté en false el servicio emite un
#        Warn en CADA arranque; ese Warn es el recordatorio de volverlo a true.
#
#        Este interruptor NO habilita la verificación. Sin BMP_CLIENT_ID /
#        BMP_CLIENT_SECRET el cliente queda deshabilitado, no se consulta a BMP
#        y la cola admin muestra 'unavailable' para todos — que es exactamente
#        el escenario para el que existe el interruptor. Cuando SÍ hay
#        credenciales, la verificación se ejecuta y se persiste igual; lo que
#        el false apaga es el bloqueo, no la observabilidad.
#
# No afecta al candado de baneados (D10), que es fail-closed siempre, ni a la
# verificación al solicitar (fail-open por diseño).
#
# Un valor ilegible ("flase") cae al default true: el error de dedo falla del
# lado seguro en vez de abrir la salida de dinero.
# ==========================================================================
WITHDRAWALS_REQUIRE_BMP=true
