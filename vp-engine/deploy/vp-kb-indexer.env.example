# vp-kb-indexer — indexer del RAG de soporte (Postgres → Qdrant)
# Producción: /etc/vicion/vp-kb-indexer.env (600 root:root) en la EC2 WORKER.
# OPENROUTER_API_KEY se obtiene del secreto OPENROUTER_API_RAG en Secrets
# Manager en el paso de deploy — NUNCA commitear el valor real.

APP_ENV=production
LOG_LEVEL=info

DATABASE_URL=postgres://vp_app:CHANGE_ME@rds-endpoint:5432/vicionpower

# aws secretsmanager get-secret-value --secret-id OPENROUTER_API_RAG \
#   --query SecretString --output text | jq -r .OPENROUTER_API_KEY
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME

# Qdrant local en el WORKER (bind privado, nunca expuesto en el SG).
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=CHANGE_ME
QDRANT_COLLECTION=kb

KB_BATCH_SIZE=128
KB_POLL_INTERVAL=30s
DB_MAX_CONNS=4
