# /etc/vicion/vp-payments.env  — variables del servicio de cobros (chmod 600).
# Go las lee del entorno (systemd EnvironmentFile), NO de un .env.

# --- Stripe (LIVE para producción; usar sk_test/whsec_test para pruebas) ---
# Acepta también los nombres CLAVE_API / SECRET_FIRMA como alias.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYMENTS_STRIPE_PRODUCT_ID=prod_Uh7XFJyzQusjkl
PAYMENTS_METHODS=card,crypto

# --- Base de datos (rol CON escritura; no el read-only) ---
# Acepta DATABASE_URL o VP_ENGINE_DATABASE_URL.
DATABASE_URL=postgres://vp_engine:***@<rds-host>:5432/vicion?sslmode=require

# --- Servicio / red ---
PAYMENTS_HTTP_ADDR=0.0.0.0:9095
# Secreto compartido con el BFF Next (mismo valor en el .env del Next):
PAYMENTS_SERVICE_TOKEN=__generar_con_openssl_rand_-hex_32__

# --- URLs de retorno de Checkout ---
PAYMENTS_SUCCESS_URL=https://app.mindblisspower.com/dashboard/packages?paid=1&session_id={CHECKOUT_SESSION_ID}
PAYMENTS_CANCEL_URL=https://app.mindblisspower.com/dashboard/packages?canceled=1

ENV=production
LOG_LEVEL=info

# Root de empresa: compradores sin ?ref ni afiliado previo se colocan aquí (derrame).
PAYMENTS_COMPANY_ROOT_AFFILIATE_ID=117475
