# vp-support — API del bot de soporte (RAG sobre la KB) + gestión de docs.
# Producción: /etc/vicion/vp-support.env (600 root:root) en la EC2 WORKER
# (mismo host que Qdrant y vp-kb-indexer).

APP_ENV=production
LOG_LEVEL=info

# Bind 0.0.0.0 si corre en contenedor bridge (lección del bug de vp-payments);
# el acceso externo lo controla el SG + Caddy, no el bind.
SUPPORT_HTTP_ADDR=0.0.0.0:9096

DATABASE_URL=postgres://vp_app:CHANGE_ME@rds-endpoint:5432/vicionpower

# Secreto OPENROUTER_API_RAG en Secrets Manager (paso de deploy lo inyecta):
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME
# LLM del bot — iterable sin tocar embeddings (los embeddings están CONGELADOS
# en multilingual-e5-large; este modelo de chat sí se puede cambiar libre).
SUPPORT_CHAT_MODEL=openai/gpt-4o-mini
# Umbral de score coseno del top hit para intentar responder (bajo ⇒ escalar).
SUPPORT_MIN_SCORE=0.45

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=CHANGE_ME
QDRANT_COLLECTION=kb

# Shared secret con el BFF Next (mismo patrón que vp-payments).
SERVICE_TOKEN=CHANGE_ME
# Allowlist de admins (rol admin de la KB; requiere id token verificado).
ADMIN_EMAILS=devfidubit@gmail.com

# Verificación H-2 del id token que reenvía el BFF (X-VP-Id-Token).
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_CHANGE_ME
COGNITO_CLIENT_ID=CHANGE_ME
