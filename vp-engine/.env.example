# vp-engine — copy to .env and fill in for local dev.
# Production values come from sops-encrypted secrets (ADR 0004).

# Postgres connection (engine_write role from schema_mlm.sql + governance)
DATABASE_URL=postgres://engine_write:CHANGEME@localhost:5432/vicionpower

# NATS JetStream (ADR 0007)
NATS_URL=nats://localhost:4222
NATS_USER=vp-engine
NATS_PASSWORD=CHANGEME

# gRPC server (vp-api connects here over private network in prod, mTLS)
GRPC_LISTEN_ADDR=0.0.0.0:50051
GRPC_TLS_CERT=/etc/vp-engine/server.crt
GRPC_TLS_KEY=/etc/vp-engine/server.key
GRPC_TLS_CLIENT_CA=/etc/vp-engine/clients-ca.crt
GRPC_TLS_REQUIRE_CLIENT_CERT=true

# HTTP for /health, /ready, /metrics and /api/network/analyze.
HTTP_LISTEN_ADDR=0.0.0.0:9090

# OpenRouter LLM analysis. If OPENROUTER_API_KEY is empty, the engine returns
# deterministic network analysis without calling an LLM.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=xiaomi/mimo-v2.5-pro
OPENROUTER_FALLBACK_MODEL=minimax/minimax-m3
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Mindbliss Power

# Observability (ADR 0011)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=vp-engine
LOG_LEVEL=info

# Bonus engine
BONUS_ENGINE_TIMEZONE=America/Bogota
BONUS_ENGINE_BINARY_CRON="0 2 * * 1"
BONUS_ENGINE_ROI_CRON="0 1 * * *"
BONUS_ENGINE_BINARY_CYCLE_ENABLED=true

# Build metadata (set by make build)
ENV=development
