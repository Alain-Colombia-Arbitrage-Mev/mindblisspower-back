# vp-kb-indexer — imagen mínima arm64 (binario estático precompilado).
# distroless/static trae CA certs y usuario nonroot; sin RUN ⇒ el build
# cross-arch no necesita emulación QEMU.
# Build (desde vp-engine/, contexto = bin/ porque .dockerignore excluye bin/):
#   docker buildx build --platform linux/arm64 -f deployments/Dockerfile.vp-kb-indexer \
#     -t $REGISTRY/vp/vp-kb-indexer:kb-v1 --push bin
FROM gcr.io/distroless/static-debian12:nonroot
COPY vp-kb-indexer-linux-arm64 /usr/local/bin/vp-kb-indexer
ENTRYPOINT ["/usr/local/bin/vp-kb-indexer"]
