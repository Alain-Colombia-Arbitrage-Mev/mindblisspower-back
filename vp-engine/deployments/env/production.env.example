# Copy to /etc/vp-engine/app.env on the EC2 host.
# Do not commit a filled production file.

ENV=production
LOG_LEVEL=info
OTEL_SERVICE_NAME=vp-engine

# Keep HTTP private when Next runs on the same EC2 host.
HTTP_LISTEN_ADDR=127.0.0.1:9090

# gRPC is for internal service-to-service traffic. In production keep mTLS on
# and restrict port 50051 to the private security group only.
GRPC_LISTEN_ADDR=0.0.0.0:50051
GRPC_TLS_CERT=/etc/vp-engine/tls/server.crt
GRPC_TLS_KEY=/etc/vp-engine/tls/server.key
GRPC_TLS_CLIENT_CA=/etc/vp-engine/tls/clients-ca.crt
GRPC_TLS_REQUIRE_CLIENT_CERT=true

DATABASE_URL=postgres://engine_write:CHANGE_ME@PRIVATE_DB_HOST:5432/vicionpower

NATS_URL=nats://PRIVATE_NATS_HOST:4222
NATS_USER=vp-engine
NATS_PASSWORD=CHANGE_ME

OPENROUTER_API_KEY=CHANGE_ME
OPENROUTER_MODEL=xiaomi/mimo-v2.5-pro
OPENROUTER_FALLBACK_MODEL=minimax/minimax-m3
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_REFERER=https://app.mindblisspower.com
OPENROUTER_APP_TITLE=Mindbliss Power

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

BONUS_ENGINE_TIMEZONE=America/Bogota
BONUS_ENGINE_BINARY_CRON="0 2 * * 1"
BONUS_ENGINE_ROI_CRON="0 1 * * *"

# Set true on exactly one active worker node until distributed locking exists.
BONUS_ENGINE_BINARY_CYCLE_ENABLED=true
