# Optional Caddy config — used only if Cloudflare is bypassed and the app
# tier terminates TLS itself. With Cloudflare Full (Strict), Caddy gets a
# Let's Encrypt cert via the HTTP-01 challenge.

{
  email ops@vicionpower.com
  servers {
    timeouts {
      read_body 10s
      read_header 5s
      write 30s
      idle 120s
    }
  }
}

app.vicionpower.com {
  encode zstd gzip

  # Trust Cloudflare's IPs as the source of X-Forwarded-For
  trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 \
                         103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 \
                         190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 \
                         198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 \
                         104.24.0.0/14 172.64.0.0/13 131.0.72.0/22

  # Rate limit aggressive scraping at the edge (optional plugin: caddy-ratelimit)
  # rate_limit { zone api { key {remote_host}; events 100; window 1m } }

  reverse_proxy 10.0.1.10:3000 10.0.1.11:3000 {
    lb_policy least_conn
    health_uri /health
    health_interval 5s
    health_timeout 2s
    fail_duration 30s
  }

  log {
    output file /var/log/caddy/app.log {
      roll_size 100mb
      roll_keep 14
    }
    format json
  }
}
