          "token.actions.githubusercontent.com:sub": [
            "repo:Alain-Colombia-Arbitrage-Mev/mindblisspower-back:ref:refs/heads/main",
            "repo:Alain-Colombia-Arbitrage-Mev/mindblisspower-back:ref:refs/heads/staging"
          ]
